\ProvidesPackage{beamerthemefastverk}[2026/06/24 fastverk beamer theme]

\RequirePackage{fontspec}
\RequirePackage{tikz}

% Brand typeface — brand_doc stages the fonts at fonts/.
\setsansfont{SpaceGrotesk-Medium.ttf}[Path=fonts/, BoldFont=SpaceGrotesk-SemiBold.ttf]
\usefonttheme{professionalfonts}

% Brand palette (dark deck — midnight).
\definecolor{fvbg}{HTML}{15161A}
\definecolor{fvfg}{HTML}{ECE7DA}
\definecolor{fvaccent}{HTML}{E0A33E}
\definecolor{fvslate}{HTML}{4A565A}

\setbeamercolor{background canvas}{bg=fvbg}
\setbeamercolor{normal text}{fg=fvfg}
\setbeamercolor{structure}{fg=fvaccent}
\setbeamercolor{title}{fg=fvfg}
\setbeamercolor{frametitle}{fg=fvfg}
\setbeamercolor{itemize item}{fg=fvaccent}
\setbeamercolor{itemize subitem}{fg=fvslate}
\setbeamercolor{block title}{fg=fvbg, bg=fvaccent}
\setbeamercolor{block body}{fg=fvfg, bg=fvslate!25}

\setbeamerfont{frametitle}{series=\bfseries, size=\Large}
\setbeamerfont{title}{series=\bfseries, size=\Huge}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{itemize item}{\small\raisebox{0.15ex}{$\blacktriangleright$}}

% Frame title with an amber underline.
\setbeamertemplate{frametitle}{%
  \vskip0.7em
  {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle}%
  \vskip0.15em
  {\color{fvaccent}\rule{\linewidth}{1.2pt}}%
}

% Quiet footline: wordmark text + slide number.
\setbeamertemplate{footline}{%
  \hfill{\color{fvslate}\scriptsize\textbf{fastverk}\quad\insertframenumber}%
  \hspace{1.2em}\vskip0.5em
}

\endinput
